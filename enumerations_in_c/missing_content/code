#include <iostream>

struct Student 
{
    // Define Level enum and member variable here
    enum Level
        {
            Freshman,
            Sophomore,
            Junior,
            Senior,
        };

    Level level;
};

bool isSenior(const Student& student)
    {
    if(student.level==Student::Senior)
        return true;
    else
        return false;
    }

// Define isSenior function here

int main()
{
    Student alice{ Student::Senior };
    Student bob{ Student::Junior };

    std::cout << "Is the student a senior? " << (isSenior(alice) ? "true" : "false") << std::endl;
    std::cout << "Is the student a senior? " << (isSenior(bob) ? "true" : "false") << std::endl;
    return 0;
}